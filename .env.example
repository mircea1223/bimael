# Runtime
NODE_ENV=development
PORT=4173
HOST=0.0.0.0
APP_BASE_URL=http://localhost:4173
LOG_LEVEL=info
SESSION_SECRET=
# Doar pentru HTTP local. În producție, elimină variabila sau setează `true`
# și termină TLS la reverse proxy.
COOKIE_SECURE=false

# Persistence
# Leave empty for the explicit demo/static data adapter. A real database is
# contacted only when a valid server-side URL is supplied.
DATABASE_URL=
# Example for local PostgreSQL:
# DATABASE_URL=postgresql://bimael:bimael@localhost:5432/bimael

# External adapters
# `demo` is the safe default. If a non-demo provider is selected but any
# required credential is missing, the application must fall back to its demo
# adapter, emit a visible startup warning, and make no real provider call.

# Payments
PAYMENT_PROVIDER=demo
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# Transactional email
EMAIL_PROVIDER=demo
EMAIL_API_KEY=
EMAIL_FROM=no-reply@example.invalid

# Webinars / video meetings
VIDEO_PROVIDER=demo
VIDEO_API_KEY=
VIDEO_WEBHOOK_SECRET=
