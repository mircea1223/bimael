{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/server?__route=/api/:path*"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/server?__route=/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/server?__route=/sitemap.xml"
    },
    {
      "source": "/rss.xml",
      "destination": "/api/server?__route=/rss.xml"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
