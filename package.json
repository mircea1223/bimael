{
  "name": "bimael-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Bimael — platformă editorială, academică și culturală",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "npm run typecheck && vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "preview": "npm run start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:flows": "vitest run src/tests/flows.test.tsx",
    "test:e2e": "playwright test",
    "perf:budget": "node scripts/check-budget.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run perf:budget && npm run test:e2e"
  },
  "dependencies": {
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.3",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  }
}
